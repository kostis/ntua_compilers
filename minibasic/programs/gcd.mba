var a : int
var b : int
let a = 42174217
let b = 17421742

for 100 do
  if a > 0 then
    if b > 0 then begin
      var x : bool
      let x = false
      for a - b do let x = true
      if x then let a = a % b
      let x = true
      for b - a do let x = false
      if x then let b = b % a
    end
print a + b
